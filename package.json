{
  "name": "20forms-20designs",
  "private": true,
  "version": "1.0.260412.54",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:shell": "cd apps/shell && bun run dev",
    "build": "bun scripts/build-all.mjs --consolidated",
    "build:all": "bun scripts/build-all.mjs",
    "build:shell": "cd apps/shell && bun run build",
    "build:copy": "bun scripts/copy-builds-to-dist.mjs",
    "preview": "bun scripts/serve-preview.mjs",
    "preview:shell": "cd apps/shell && bun run preview",
    "clean": "bun scripts/clean.mjs",
    "lint": "eslint 'apps/*/src/**/*.{js,jsx,ts,tsx}' 'packages/*/src/**/*.{js,jsx,ts,tsx}' --cache",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "sloc": "bun scripts/calc-sloc.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "@cloudscape-design/component-toolkit": "1.0.0-beta.156"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
